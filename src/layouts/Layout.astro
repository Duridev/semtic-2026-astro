---
import SchemaOrgJsonLd from "../components/SchemaOrgJsonLd.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
    ogType?: string;
}

const {
    title,
    description = "SEMTIC - Agencia digital especializada en desarrollo web, diseño gráfico y marketing digital. Creamos soluciones innovadoras para tu presencia online.",
    image = "https://semtic.cl/og-image.png",
    ogType = "website",
} = Astro.props;

const siteUrl = "https://semtic.cl";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="agencia digital, desarrollo web, diseño web, e-commerce, marketing digital, SEO, SEM, redes sociales, diseño gráfico, páginas web, gestión de redes"
        />
        <meta name="author" content="SEMTIC Agencia Digital" />
        <meta name="robots" content="index, follow" />
        <meta
            name="google-site-verification"
            content="1uHPJWK3tVX4vQR12OXyNio0-6A618MFvv1JU5CgL_I"
        />
        <meta name="theme-color" content="#050511" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />

        <!-- Canonical URL -->
        <link rel="canonical" href={canonicalUrl.toString()} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl.toString()} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="SEMTIC Agencia Digital" />
        <meta property="og:locale" content="es_CL" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalUrl.toString()} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <!-- Additional SEO -->
        <meta name="language" content="Spanish" />
        <meta name="revisit-after" content="7 days" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />

        <!-- Schema.org Structured Data -->
        <SchemaOrgJsonLd />
        <title>{title} | SEMTIC</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Space+Grotesk:wght@300;500;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/webp" href="/semtic-favicon.webp" />
        <link rel="alternate" hreflang="es-CL" href={canonicalUrl.toString()} />
    </head>
    <body class="antialiased selection:bg-[#2dd4bf] selection:text-[#050511]">
        <!-- Canvas para el efecto de partículas de fondo -->
        <canvas
            id="bgCanvas"
            class="fixed top-0 left-0 w-full h-full opacity-50"
            style="z-index: 1; pointer-events: none;"></canvas>

        <!-- Capa de ruido/estrellas estática -->
        <div
            class="fixed top-0 left-0 w-full h-full stars-bg opacity-25"
            style="z-index: 0; pointer-events: none;"
        >
        </div>

        <!-- Navbar -->
        <nav
            class="fixed w-full transition-all duration-300 px-3 md:px-6 py-4 glass border-b-0"
            style="z-index: 100; max-width: 100vw;"
        >
            <div class="max-w-7xl mx-auto flex justify-between items-center">
                <!-- Logo Brand -->
                <a href="/" class="flex items-center group">
                    <img
                        src="/logo-semtic.png"
                        alt="SEMTIC - Agencia de desarrollo web y marketing digital en Chile"
                        class="h-6 md:h-10 w-auto"
                    />
                </a>

                <!-- Desktop Menu -->
                <div class="hidden md:flex gap-8 items-center">
                    <a
                        href="/"
                        class="text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all"
                        >Inicio</a
                    >
                    <div class="relative group py-4">
                        <a
                            href="/#servicios"
                            class="text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all flex items-center gap-1"
                        >
                            Servicios
                            <svg
                                class="w-4 h-4 transition-transform group-hover:rotate-180"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path></svg
                            >
                        </a>
                        <div
                            class="absolute top-full -left-4 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300"
                            style="z-index: 150;"
                        >
                            <div
                                class="w-64 bg-[#0a0a1a]/95 backdrop-blur-xl border border-white/10 rounded-xl shadow-2xl overflow-hidden py-2 relative"
                            >
                                <div
                                    class="absolute inset-0 bg-gradient-to-br from-[#2dd4bf]/10 to-transparent pointer-events-none"
                                >
                                </div>
                                <a
                                    href="/agencia-marketing-digital"
                                    class="block px-4 py-3 text-sm text-gray-300 hover:bg-white/10 hover:text-[#2dd4bf] transition-colors relative z-10"
                                    >Agencia de Marketing Digital</a
                                >
                                <a
                                    href="/desarrollo-paginas-web"
                                    class="block px-4 py-3 text-sm text-gray-300 hover:bg-white/10 hover:text-[#2dd4bf] transition-colors relative z-10"
                                    >Desarrollo de Páginas Web</a
                                >
                                <a
                                    href="/publicidad-google-meta-ads"
                                    class="block px-4 py-3 text-sm text-gray-300 hover:bg-white/10 hover:text-[#2dd4bf] transition-colors relative z-10"
                                    >Publicidad en Google y Meta Ads</a
                                >
                            </div>
                        </div>
                    </div>
                    <a
                        href="/nosotros"
                        class="text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all"
                        >Nosotros</a
                    >
                    <a
                        href="/faq"
                        class="text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all"
                        >FAQ</a
                    >
                    <a
                        href="/contacto"
                        class="px-6 py-2 rounded-full border border-[#2dd4bf] text-[#2dd4bf] hover:bg-[#2dd4bf] hover:text-[#050511] transition-all duration-300 font-semibold text-sm tracking-wide"
                    >
                        Hablemos
                    </a>
                </div>

                <!-- Mobile Menu Button -->
                <button
                    id="mobile-menu-btn"
                    class="md:hidden text-white focus:outline-none"
                    aria-label="Abrir menú de navegación"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                >
                    <svg
                        id="menu-open-icon"
                        class="h-6 w-6 transition-transform"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg
                        id="menu-close-icon"
                        class="h-6 w-6 hidden transition-transform"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        aria-hidden="true"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>

            <!-- Mobile Menu -->
            <div id="mobile-menu" class="md:hidden">
                <div
                    class="mx-3 mt-4 px-4 pt-4 pb-6 space-y-3 bg-[#4f46e5]/30 backdrop-blur-md border border-[#4f46e5]/40 rounded-2xl"
                >
                    <a
                        href="/"
                        class="block text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all py-3 px-4 rounded-lg hover:bg-white/5"
                        >Inicio</a
                    >
                    <div>
                        <div
                            class="flex items-center justify-between rounded-lg hover:bg-white/5 pr-4"
                        >
                            <a
                                href="/#servicios"
                                class="block w-full text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all py-3 px-4"
                                >Servicios</a
                            >
                            <button
                                onclick="document.getElementById('mobile-servicios-dropdown').classList.toggle('hidden'); document.getElementById('mobile-servicios-icon').classList.toggle('rotate-180')"
                                class="p-2 text-gray-400 focus:outline-none"
                            >
                                <svg
                                    id="mobile-servicios-icon"
                                    class="w-5 h-5 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </button>
                        </div>
                        <div
                            id="mobile-servicios-dropdown"
                            class="hidden pl-8 pr-4 py-2 border-l border-white/10 ml-6 mt-1"
                        >
                            <a
                                href="/agencia-marketing-digital"
                                class="block text-sm text-gray-400 hover:text-[#2dd4bf] transition-colors py-2"
                                >Agencia de Marketing Digital</a
                            >
                            <a
                                href="/desarrollo-paginas-web"
                                class="block text-sm text-gray-400 hover:text-[#2dd4bf] transition-colors py-2"
                                >Desarrollo de Páginas Web</a
                            >
                            <a
                                href="/publicidad-google-meta-ads"
                                class="block text-sm text-gray-400 hover:text-[#2dd4bf] transition-colors py-2"
                                >Publicidad en Google y Meta Ads</a
                            >
                        </div>
                    </div>
                    <a
                        href="/nosotros"
                        class="block text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all py-3 px-4 rounded-lg hover:bg-white/5"
                        >Nosotros</a
                    >
                    <a
                        href="/faq"
                        class="block text-sm uppercase tracking-widest text-gray-300 hover:text-[#2dd4bf] hover:drop-shadow-[0_0_8px_rgba(45,212,191,0.8)] transition-all py-3 px-4 rounded-lg hover:bg-white/5"
                        >FAQ</a
                    >
                    <a
                        href="/contacto"
                        class="block text-center px-6 py-3 rounded-full border border-[#2dd4bf] text-[#2dd4bf] hover:bg-[#2dd4bf] hover:text-[#050511] transition-all duration-300 font-semibold text-sm tracking-wide"
                        >Hablemos</a
                    >
                </div>
            </div>
        </nav>

        <!-- Main Content -->
        <main>
            <slot />
        </main>

        <!-- Footer -->
        <footer
            class="py-12 border-t border-white/10 text-center text-gray-400 text-base"
            style="z-index: 10; background: rgba(5, 5, 17, 0.95);"
        >
            <div class="container mx-auto px-4">
                <div
                    class="flex flex-col md:flex-row justify-between items-center gap-6 md:gap-4 mb-8"
                >
                    <div>
                        <img
                            src="/logo-semtic.png"
                            alt="SEMTIC - Agencia de marketing digital"
                            class="h-8 md:h-10 w-auto mx-auto md:mx-0"
                        />
                    </div>
                    <div
                        class="flex flex-wrap justify-center gap-6 text-gray-300 font-medium"
                    >
                        <a
                            href="/"
                            class="hover:text-[#2dd4bf] transition-colors"
                            >Inicio</a
                        >
                        <a
                            href="/#servicios"
                            class="hover:text-[#2dd4bf] transition-colors"
                            >Servicios</a
                        >
                        <a
                            href="/nosotros"
                            class="hover:text-[#2dd4bf] transition-colors"
                            >Nosotros</a
                        >
                        <a
                            href="/faq"
                            class="hover:text-[#2dd4bf] transition-colors"
                            >FAQ</a
                        >
                        <a
                            href="/contacto"
                            class="hover:text-[#2dd4bf] transition-colors"
                            >Contacto</a
                        >
                    </div>
                </div>
                <p class="text-gray-500 text-sm md:text-base">
                    © 2026 SEMTIC Agencia. Todos los derechos reservados.
                </p>
            </div>
        </footer>

        <script>
            // Background particles
            const bgCanvas = document.getElementById("bgCanvas");
            const bgCtx = bgCanvas.getContext("2d");

            let bgWidth, bgHeight;
            let bgParticles = [];

            function resizeBg() {
                bgWidth = bgCanvas.width = window.innerWidth;
                bgHeight = bgCanvas.height = window.innerHeight;
            }
            window.addEventListener("resize", resizeBg);
            resizeBg();

            class BgParticle {
                constructor() {
                    this.x = Math.random() * bgWidth;
                    this.y = Math.random() * bgHeight;
                    this.vx = (Math.random() - 0.5) * 0.5;
                    this.vy = (Math.random() - 0.5) * 0.5;
                    this.size = Math.random() * 2.5;
                    this.color = Math.random() > 0.5 ? "#00f2ea" : "#b026ff";
                }

                update() {
                    this.x += this.vx;
                    this.y += this.vy;

                    if (this.x < 0) this.x = bgWidth;
                    if (this.x > bgWidth) this.x = 0;
                    if (this.y < 0) this.y = bgHeight;
                    if (this.y > bgHeight) this.y = 0;
                }

                draw() {
                    bgCtx.beginPath();
                    bgCtx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    bgCtx.fillStyle = this.color;
                    bgCtx.globalAlpha = 0.5;
                    bgCtx.fill();
                }
            }

            for (let i = 0; i < 80; i++) {
                bgParticles.push(new BgParticle());
            }

            function animateBg() {
                bgCtx.clearRect(0, 0, bgWidth, bgHeight);

                for (let i = 0; i < bgParticles.length; i++) {
                    bgParticles[i].update();
                    bgParticles[i].draw();

                    for (let j = i; j < bgParticles.length; j++) {
                        const dx = bgParticles[i].x - bgParticles[j].x;
                        const dy = bgParticles[i].y - bgParticles[j].y;
                        const distance = Math.sqrt(dx * dx + dy * dy);

                        if (distance < 150) {
                            bgCtx.beginPath();
                            bgCtx.strokeStyle = bgParticles[i].color;
                            bgCtx.globalAlpha = 0.15 - (distance / 150) * 0.15;
                            bgCtx.lineWidth = 0.8;
                            bgCtx.moveTo(bgParticles[i].x, bgParticles[i].y);
                            bgCtx.lineTo(bgParticles[j].x, bgParticles[j].y);
                            bgCtx.stroke();
                        }
                    }
                }
                requestAnimationFrame(animateBg);
            }
            animateBg();

            // Mobile menu toggle
            const mobileMenuBtn = document.getElementById("mobile-menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            const menuOpenIcon = document.getElementById("menu-open-icon");
            const menuCloseIcon = document.getElementById("menu-close-icon");

            if (mobileMenuBtn && mobileMenu) {
                mobileMenuBtn.addEventListener("click", () => {
                    const isOpen = mobileMenu.classList.toggle("active");
                    menuOpenIcon.classList.toggle("hidden");
                    menuCloseIcon.classList.toggle("hidden");
                    mobileMenuBtn.setAttribute("aria-expanded", isOpen);
                    mobileMenuBtn.setAttribute(
                        "aria-label",
                        isOpen
                            ? "Cerrar menú de navegación"
                            : "Abrir menú de navegación",
                    );
                });

                const mobileLinks = mobileMenu.querySelectorAll("a");
                mobileLinks.forEach((link) => {
                    link.addEventListener("click", () => {
                        mobileMenu.classList.remove("active");
                        menuOpenIcon.classList.remove("hidden");
                        menuCloseIcon.classList.add("hidden");
                        mobileMenuBtn.setAttribute("aria-expanded", "false");
                        mobileMenuBtn.setAttribute(
                            "aria-label",
                            "Abrir menú de navegación",
                        );
                    });
                });
            }
        </script>
    </body>
</html>
