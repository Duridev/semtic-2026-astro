---
import SchemaOrgJsonLd from "../components/SchemaOrgJsonLd.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
    ogType?: string;
}

const {
    title,
    description = "SEMTIC - Agencia digital especializada en desarrollo web, diseño gráfico y marketing digital. Creamos soluciones innovadoras para tu presencia online.",
    image = "https://semtic.cl/og-image.png",
    ogType = "website",
} = Astro.props;

const siteUrl = "https://semtic.cl";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="agencia digital, desarrollo web, diseño web, e-commerce, marketing digital, SEO, SEM, redes sociales, agencia de marketing, Limache, Marga Marga, Olmué, Villa Alemana, Quilpué, Quillota, Viña del Mar, Valparaíso"
        />
        <meta name="author" content="SEMTIC Agencia Digital" />
        <meta name="robots" content="index, follow" />
        <meta
            name="google-site-verification"
            content="1uHPJWK3tVX4vQR12OXyNio0-6A618MFvv1JU5CgL_I"
        />
        <meta name="theme-color" content="#050511" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />

        <!-- Canonical URL -->
        <link rel="canonical" href={canonicalUrl.toString()} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl.toString()} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:image:alt" content={title} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="SEMTIC Agencia Digital" />
        <meta property="og:locale" content="es_CL" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalUrl.toString()} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={image} />

        <!-- Additional SEO -->
        <meta name="language" content="Spanish" />
        <meta name="revisit-after" content="7 days" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />

        <!-- Schema.org Structured Data -->
        <SchemaOrgJsonLd />
        <title>{title} | SEMTIC</title>
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Space+Grotesk:wght@300;500;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/webp" href="/semtic-favicon.webp" />
        <link rel="alternate" hreflang="es-CL" href={canonicalUrl.toString()} />
    </head>
    <body class="antialiased selection:bg-[#2dd4bf] selection:text-[#050511] text-gray-200">
        <!-- Canvas para el efecto de partículas de fondo -->
        <canvas
            id="bgCanvas"
            class="fixed top-0 left-0 w-full h-full opacity-50"
            style="z-index: 1; pointer-events: none;"></canvas>

        <!-- Capa de ruido/estrellas estática -->
        <div
