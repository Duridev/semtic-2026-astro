---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout 
    title="Publicidad en Google y Meta Ads | SEMTIC" 
    description="Gestionamos tus campañas de publicidad digital en Google Ads, Facebook e Instagram para maximizar tu retorno de inversión."
    image="https://semtic.cl/og-servicios.png">

    <!-- SECCIÓN 1: HERO -->
    <section class="relative min-h-[60vh] flex items-center justify-center pt-32 pb-20 overflow-hidden" style="z-index: 10;">
        <div class="absolute top-1/4 left-1/4 w-64 md:w-96 h-64 md:h-96 bg-[#39ff14] rounded-full mix-blend-screen filter blur-[128px] opacity-20 animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-64 md:w-96 h-64 md:h-96 bg-[#00f2ea] rounded-full mix-blend-screen filter blur-[128px] opacity-20 animate-pulse" style="animation-delay: 2s;"></div>

        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-[family-name:var(--font-space-grotesk)] font-bold mb-6 leading-tight">
                Campañas de Google y Meta Ads <br class="hidden lg:block"/><span class="text-gradient">Optimizadas para Multiplicar tus Ventas.</span>
            </h1>
            <p class="text-gray-300 text-lg md:text-xl max-w-3xl mx-auto mb-10 font-light leading-relaxed">
                Ponemos tu marca frente a las personas exactas en el momento preciso en que están listas para comprar.
            </p>
        </div>
    </section>

    <!-- SECCIÓN 2: EL "DOLOR" DEL CLIENTE (Bloque de impacto) -->
    <section class="py-10 md:py-20 relative" style="z-index: 10;">
        <div class="container mx-auto px-4">
            <div class="max-w-5xl mx-auto p-10 md:p-16 rounded-[2.5rem] bg-[#0a0a1a]/80 border border-white/5 backdrop-blur-xl text-center relative overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-1 bg-gradient-to-r from-transparent via-[#39ff14] to-transparent opacity-50"></div>
                <h2 class="text-sm md:text-base font-bold mb-6 text-[#39ff14] tracking-[0.25em] uppercase">¿Cansado de tirar tu dinero a la basura?</h2>
                <p class="text-lg md:text-2xl text-gray-300 leading-relaxed font-light">
                    Configurar un anuncio es fácil; hacer que sea rentable es el verdadero desafío. Si has intentado usar el botón 'Promocionar' y no has visto resultados, <span class="text-[#39ff14] font-medium">necesitas un equipo de especialistas.</span> Nosotros gestionamos tu presupuesto publicitario como si fuera nuestro.
                </p>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 3: NUESTRA SOLUCIÓN (Grid de 3 Tarjetas) -->
    <section class="py-20 relative" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.3), rgba(5, 5, 17, 0.6));">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
                <!-- Tarjeta 1 - Google Ads -->
                <div class="group relative p-8 md:p-10 rounded-3xl bg-[#0a0a1a]/50 border border-white/5 backdrop-blur-md hover:border-[#39ff14]/40 transition-all duration-500 hover:-translate-y-2 shadow-xl hover:shadow-[0_10px_40px_-15px_rgba(57,255,20,0.3)]">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#39ff14]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-3xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-2xl bg-gradient-to-br from-[#39ff14]/20 to-transparent flex items-center justify-center text-[#39ff14] border border-[#39ff14]/20 group-hover:bg-[#39ff14]/30 transition-colors">
                            <svg class="w-8 h-8 drop-shadow-[0_0_12px_rgba(57,255,20,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4 font-[family-name:var(--font-space-grotesk)] leading-tight">Google Ads <br/><span class="text-lg font-normal text-gray-400">(Intención de Búsqueda)</span></h3>
                        <p class="text-gray-300 text-base md:text-lg leading-relaxed mb-6">
                            Captamos a los clientes que ya están buscando en Google exactamente lo que tú vendes.
                        </p>
                    </div>
                </div>

                <!-- Tarjeta 2 - Meta Ads -->
                <div class="group relative p-8 md:p-10 rounded-3xl bg-[#0a0a1a]/50 border border-white/5 backdrop-blur-md hover:border-[#1877F2]/40 transition-all duration-500 hover:-translate-y-2 shadow-xl hover:shadow-[0_10px_40px_-15px_rgba(24,119,242,0.3)]">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#1877F2]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-3xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-2xl bg-gradient-to-br from-[#1877F2]/20 to-transparent flex items-center justify-center text-[#1877F2] border border-[#1877F2]/20 group-hover:bg-[#1877F2]/30 transition-colors">
                            <svg class="w-8 h-8 drop-shadow-[0_0_12px_rgba(24,119,242,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4 font-[family-name:var(--font-space-grotesk)] leading-tight">Meta Ads <br/><span class="text-lg font-normal text-gray-400">(Interrupción Estratégica)</span></h3>
                        <p class="text-gray-300 text-base md:text-lg leading-relaxed mb-6">
                            Creamos anuncios en Facebook e Instagram que detienen el scroll y generan interés inmediato.
                        </p>
                    </div>
                </div>

                <!-- Tarjeta 3 - Optimización -->
                <div class="group relative p-8 md:p-10 rounded-3xl bg-[#0a0a1a]/50 border border-white/5 backdrop-blur-md hover:border-[#00f2ea]/40 transition-all duration-500 hover:-translate-y-2 shadow-xl hover:shadow-[0_10px_40px_-15px_rgba(0,242,234,0.3)]">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#00f2ea]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-3xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-2xl bg-gradient-to-br from-[#00f2ea]/20 to-transparent flex items-center justify-center text-[#00f2ea] border border-[#00f2ea]/20 group-hover:bg-[#00f2ea]/30 transition-colors">
                            <svg class="w-8 h-8 drop-shadow-[0_0_12px_rgba(0,242,234,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4 font-[family-name:var(--font-space-grotesk)] leading-tight">Optimización <br/><span class="text-lg font-normal text-gray-400 block mt-2">Continua</span></h3>
                        <p class="text-gray-300 text-base md:text-lg leading-relaxed mb-6">
                            Monitoreamos y ajustamos a diario para bajar tu costo por adquisición (CPA) y maximizar tu retorno de inversión (ROI).
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 4: QUÉ INCLUYE NUESTRO SERVICIO -->
    <section class="py-20 relative" style="z-index: 10;">
        <div class="container mx-auto px-4">
            <div class="max-w-5xl mx-auto p-10 md:p-14 rounded-[2.5rem] bg-[#0a0a1a]/60 border border-white/5 backdrop-blur-md relative overflow-hidden group hover:border-[#00f2ea]/30 transition-all duration-300 shadow-[0_15px_40px_rgba(0,0,0,0.5)]">
                <div class="absolute bottom-0 right-0 w-64 h-64 bg-[#00f2ea] rounded-full mix-blend-screen filter blur-[150px] opacity-20 pointer-events-none transition-opacity duration-500 group-hover:opacity-40"></div>
                
                <div class="flex flex-col md:flex-row gap-12 items-center relative z-10">
                    <div class="md:w-1/3 text-center md:text-left">
                        <div class="w-20 h-20 mx-auto md:mx-0 mb-6 rounded-3xl bg-gradient-to-br from-[#00f2ea]/20 to-transparent flex items-center justify-center text-[#00f2ea] border border-[#00f2ea]/20 shadow-[0_0_15px_rgba(0,242,234,0.2)]">
                            <svg class="w-10 h-10 drop-shadow-[0_0_12px_rgba(0,242,234,0.5)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-[family-name:var(--font-space-grotesk)] font-bold mb-4 text-white leading-tight">Gestión Integral de Campañas</h2>
                        <p class="text-gray-400 font-light">
                            Dejamos de lado las conjeturas. Nuestro equipo aplica una metodología estricta para garantizar que cada centavo invertido te acerque a la meta.
                        </p>
                    </div>
                    
                    <div class="md:w-2/3 w-full">
                        <ul class="space-y-4">
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Configuración y estructura profesional de campañas.</span>
                            </li>
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Segmentación avanzada de audiencias.</span>
                            </li>
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Creación de piezas publicitarias persuasivas.</span>
                            </li>
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Pruebas A/B de anuncios para encontrar lo que mejor funciona.</span>
                            </li>
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Optimización continua de rendimiento.</span>
                            </li>
                            <li class="flex items-start gap-4 p-4 rounded-2xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/5">
                                <span class="text-[#00f2ea] mt-1 text-xl flex-shrink-0 drop-shadow-[0_0_8px_rgba(0,242,234,0.8)]">✔</span> 
                                <span class="text-gray-300 text-lg">Seguimiento de métricas clave y reportes de resultados.</span>
                            </li>
                        </ul>
                    </div>
                </div>
                
                <div class="mt-10 pt-6 border-t border-white/10 text-center relative z-10 w-full">
                    <p class="text-gray-500 text-sm italic">* La inversión publicitaria en las plataformas es independiente del valor de nuestro servicio de gestión.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 5: CALL TO ACTION FINAL -->
    <section class="py-24 relative overflow-hidden" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.8), rgba(5, 5, 17, 0.95));">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg h-64 bg-[#00f2ea] rounded-full mix-blend-screen filter blur-[150px] opacity-20 pointer-events-none"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h2 class="text-4xl md:text-5xl lg:text-5xl font-[family-name:var(--font-space-grotesk)] font-bold mb-12 max-w-4xl mx-auto leading-tight">
                <span class="text-white">Estás a un clic de dejar de gastar y</span> <br class="hidden md:block"/> <span class="text-gradient hover-glow">empezar a invertir.</span>
            </h2>
            <div class="flex flex-col items-center justify-center">
                <a href="https://wa.me/56988169404?text=Hola,%20necesito%20ayuda%20gestionando%20mis%20campañas%20de%20Google%20y%20Meta%20Ads" target="_blank" class="inline-flex items-center justify-center px-10 md:px-14 py-5 bg-gradient-to-r from-[#25D366] to-[#00f2ea] rounded-full text-[#050511] font-extrabold text-sm md:text-xl tracking-[0.05em] shadow-lg hover:shadow-[0_0_40px_rgba(0,242,234,0.3)] transition-all duration-300 transform hover:-translate-y-1 uppercase group">
                    📈 Quiero Empezar a Generar Leads
                    <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
                </a>
            </div>
        </div>
    </section>

</Layout>
