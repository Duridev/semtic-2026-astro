---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout 
    title="Desarrollo Web y Marketing Digital | SEMTIC Agencia" 
    description="Agencia digital en Chile especializada en desarrollo web, e-commerce, SEO y marketing digital. Aumenta tus ventas online con soluciones innovadoras." 
    image="https://semtic.cl/og-home.png"
    ogType="website">


    <!-- Canvas Background for Torus Animation -->
    <div id="canvas-container">
        <canvas id="torusCanvas"></canvas>
    </div>
    <!-- Hero Section -->
    <header id="home" class="relative min-h-screen flex items-center justify-center pt-32 pb-16 overflow-hidden" style="z-index: 10;">
        <!-- Glow effects -->
        <div class="absolute top-1/4 left-1/4 w-64 md:w-96 h-64 md:h-96 bg-[#4f46e5] rounded-full mix-blend-screen filter blur-[128px] opacity-20 animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-64 md:w-96 h-64 md:h-96 bg-[#2dd4bf] rounded-full mix-blend-screen filter blur-[128px] opacity-20 animate-pulse" style="animation-delay: 2s;"></div>

        <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
            <span class="inline-block py-1 px-3 rounded-full bg-white/5 border border-white/10 text-[#2dd4bf] text-xs font-bold tracking-[0.2em] mb-6 uppercase">
                Energía Digital &bull; Desarrollo Web &bull; Marketing
            </span>
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-[family-name:var(--font-space-grotesk)] font-bold mb-6 leading-tight">
                Sistemas Digitales y Publicidad que <br class="hidden md:block">
                <span class="text-gradient">Multiplican tus Ventas</span>
            </h1>
            <p class="text-gray-300 text-lg md:text-xl max-w-3xl mx-auto mb-10 font-light leading-relaxed">
                Especialistas en desarrollo web premium y estrategias de Google & Meta Ads para escalar negocios en Chile. Dejamos las métricas de vanidad atrás; nos enfocamos en tu retorno de inversión.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center items-center mt-12 mb-10">
                <a href="https://wa.me/56988169404?text=Hola%20Semtic!%20Estoy%20buscando%20escalar%20las%20ventas%20de%20mi%20negocio%20digital%20y%20me%20gustaría%20recibir%20asesoría." target="_blank" class="px-8 py-4 bg-gradient-to-r from-[#2dd4bf] to-[#3b82f6] rounded-full text-[#050511] font-extrabold tracking-wide hover:shadow-[0_0_30px_rgba(45,212,191,0.5)] transition-all duration-300 transform hover:-translate-y-1 uppercase text-sm">
                    🚀 Agendar Asesoría Gratuita
                </a>
                <a href="#servicios" class="px-8 py-4 glass rounded-full text-white font-semibold hover:bg-white/10 transition-all duration-300 text-sm uppercase tracking-wide">
                    Ver Servicios
                </a>
            </div>
        </div>
    </header>

    <!-- Social Proof -->
    <section class="py-16 md:py-20 border-y border-white/5 bg-[#0a0a1a]/50 backdrop-blur-sm relative z-10 hidden md:block">
        <div class="container mx-auto px-4">
            <p class="text-center text-gray-500 text-xs font-semibold tracking-[0.2em] uppercase mb-8">Empresas que confían su crecimiento en Semtic</p>
            <div class="flex flex-wrap justify-center items-center gap-12 lg:gap-24 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
                <span class="text-2xl font-[family-name:var(--font-space-grotesk)] font-bold text-white tracking-widest hover:text-[#00f2ea] transition-colors cursor-default">REBBEL ARQ.</span>
                <span class="text-2xl font-[family-name:var(--font-space-grotesk)] font-bold text-white tracking-widest hover:text-[#00f2ea] transition-colors cursor-default">TRADEMAQ</span>
                <span class="text-2xl font-[family-name:var(--font-space-grotesk)] font-bold text-white italic hover:text-[#00f2ea] transition-colors cursor-default">AGROSILVER</span>
            </div>
        </div>
    </section>

    <!-- Servicios -->
    <section id="servicios" class="py-24 relative" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.3), rgba(5, 5, 17, 0.6));">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-[family-name:var(--font-space-grotesk)] font-bold mb-6">
                    Nuestras <span class="text-gradient">Dimensiones</span>
                </h2>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Servicios diseñados para impulsar tu presencia digital con soluciones innovadoras y efectivas.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
                <!-- Card 1: Agencia de Marketing Digital -->
                <div class="group relative p-6 xl:p-8 rounded-2xl bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#4f46e5]/50 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#4f46e5]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-xl bg-white/5 flex items-center justify-center text-[#4f46e5] border border-white/10 group-hover:shadow-[0_0_20px_rgba(79,70,229,0.4)] transition-shadow">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white font-[family-name:var(--font-space-grotesk)]">Agencia de Marketing Digital</h3>
                        <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 flex-grow">
                            Estrategias digitales integrales enfocadas en potenciar tu marca, atraer clientes y multiplicar tus ventas de manera constante.
                        </p>
                        <a href="/agencia-marketing-digital" class="text-[#4f46e5] font-semibold hover:underline mt-auto inline-block text-base tracking-wide">Ver más →</a>
                    </div>
                </div>

                <!-- Card 2: Desarrollo Web -->
                <div class="group relative p-6 xl:p-8 rounded-2xl bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#00f2ea]/50 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#00f2ea]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-xl bg-white/5 flex items-center justify-center text-[#00f2ea] border border-white/10 group-hover:shadow-[0_0_20px_rgba(0,242,234,0.4)] transition-shadow">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white font-[family-name:var(--font-space-grotesk)]">Desarrollo de Páginas Web</h3>
                        <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 flex-grow">
                            Arquitectura digital robusta y de vanguardia. Sitios web rápidos y optimizados para convertir cada visita en una oportunidad.
                        </p>
                        <a href="/desarrollo-paginas-web" class="text-[#00f2ea] font-semibold hover:underline mt-auto inline-block text-base tracking-wide">Ver más →</a>
                    </div>
                </div>

                <!-- Card 3: Publicidad Ads -->
                <div class="group relative p-6 xl:p-8 rounded-2xl bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#39ff14]/50 transition-all duration-500 hover:-translate-y-2">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#39ff14]/10 to-transparent opacity-0 group-hover:opacity-100 rounded-2xl transition-opacity duration-500"></div>
                    <div class="relative z-10 flex flex-col h-full">
                        <div class="w-16 h-16 mb-8 rounded-xl bg-white/5 flex items-center justify-center text-[#39ff14] border border-white/10 group-hover:shadow-[0_0_20px_rgba(57,255,20,0.4)] transition-shadow">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                        </div>
                        <h3 class="text-2xl font-bold mb-4 text-white font-[family-name:var(--font-space-grotesk)]">Publicidad (Google & Meta)</h3>
                        <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 flex-grow">
                            Campañas hipersegmentadas en el momento justo. Haz que tus clientes ideales te encuentren cuando tienen intención de compra.
                        </p>
                        <a href="/publicidad-google-meta-ads" class="text-[#39ff14] font-semibold hover:underline mt-auto inline-block text-base tracking-wide">Ver más →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    
    <!-- Portafolio -->
    <section id="portafolio" class="py-24 relative" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.7), rgba(5, 5, 17, 0.85));">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-[family-name:var(--font-space-grotesk)] font-bold mb-6">
                    Nuestro <span class="text-gradient">Portafolio</span>
                </h2>
                <p class="text-gray-400 max-w-2xl mx-auto">
                    Proyectos que reflejan nuestra filosofía: diseño impecable, código limpio y resultados medibles.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <!-- Portfolio Card 1 - TradeMaq -->
                <div class="group relative rounded-2xl overflow-hidden bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#00f2ea]/50 transition-all duration-500 hover:-translate-y-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#00f2ea]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    
                    <!-- Image -->
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/trademaq-hero.webp" alt="TradeMaq - Sitio web de corretaje de maquinaria diseñado por SEMTIC" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-t from-[#050511]/80 to-transparent"></div>
                    </div>

                    <!-- Content -->
                    <div class="p-6 relative z-10">
                        <h3 class="text-xl font-bold mb-2 text-white font-[family-name:var(--font-space-grotesk)] group-hover:text-[#00f2ea] transition-colors">TradeMaq</h3>
                        <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                            Plataforma de corretaje especializada en maquinaria y maquinaria pesada con catálogo dinámico y sistema de cotizaciones.
                        </p>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="px-3 py-1 bg-[#00f2ea]/10 border border-[#00f2ea]/30 rounded-full text-[#00f2ea] text-xs">Desarrollo Web Premium</span>
                            <span class="px-3 py-1 bg-[#00f2ea]/10 border border-[#00f2ea]/30 rounded-full text-[#00f2ea] text-xs">Catálogo Dinámico</span>
                            <span class="px-3 py-1 bg-[#00f2ea]/10 border border-[#00f2ea]/30 rounded-full text-[#00f2ea] text-xs">Captación de Leads</span>
                        </div>
                        <a href="https://dancing-begonia-f2bffb.netlify.app/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-[#00f2ea] text-sm font-semibold group-hover:gap-3 gap-2 transition-all">
                            Ver proyecto 
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Portfolio Card 2 - Rebbel -->
                <div class="group relative rounded-2xl overflow-hidden bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#4f46e5]/50 transition-all duration-500 hover:-translate-y-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#4f46e5]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    
                    <!-- Image -->
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/rebbel-hero.webp" alt="Rebbel - Sitio web de arquitecto en Limache desarrollado por SEMTIC" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-t from-[#050511]/80 to-transparent"></div>
                    </div>

                    <!-- Content -->
                    <div class="p-6 relative z-10">
                        <h3 class="text-xl font-bold mb-2 text-white font-[family-name:var(--font-space-grotesk)] group-hover:text-[#4f46e5] transition-colors">Rebbel Arquitectura</h3>
                        <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                            Portafolio profesional para arquitecto en Limache, destacando proyectos con galería visual y formulario de contacto.
                        </p>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="px-3 py-1 bg-[#4f46e5]/10 border border-[#4f46e5]/30 rounded-full text-[#4f46e5] text-xs">Portafolio Conversional</span>
                            <span class="px-3 py-1 bg-[#4f46e5]/10 border border-[#4f46e5]/30 rounded-full text-[#4f46e5] text-xs">Diseño UI/UX</span>
                            <span class="px-3 py-1 bg-[#4f46e5]/10 border border-[#4f46e5]/30 rounded-full text-[#4f46e5] text-xs">SEO Local</span>
                        </div>
                        <a href="https://rebbel.cl" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-[#4f46e5] text-sm font-semibold group-hover:gap-3 gap-2 transition-all">
                            Ver proyecto 
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Portfolio Card 3 - Agrosilver -->
                <div class="group relative rounded-2xl overflow-hidden bg-[#0a0a1a]/40 border border-white/5 backdrop-blur-md hover:border-[#39ff14]/50 transition-all duration-500 hover:-translate-y-3">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#39ff14]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    
                    <!-- Image -->
                    <div class="aspect-video relative overflow-hidden">
                        <img src="/agrosilver-hero.webp" alt="Agrosilver - Sitio web de servicios de jardinería diseñado por SEMTIC" class="w-full h-full object-cover">
                        <div class="absolute inset-0 bg-gradient-to-t from-[#050511]/80 to-transparent"></div>
                    </div>

                    <!-- Content -->
                    <div class="p-6 relative z-10">
                        <h3 class="text-xl font-bold mb-2 text-white font-[family-name:var(--font-space-grotesk)] group-hover:text-[#39ff14] transition-colors">Agrosilver</h3>
                        <p class="text-gray-400 text-sm mb-4 leading-relaxed">
                            Sitio web profesional para servicios de jardinería, fumigaciones, chipeado y cortes con presentación de servicios.
                        </p>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="px-3 py-1 bg-[#39ff14]/10 border border-[#39ff14]/30 rounded-full text-[#39ff14] text-xs">Generación de Contactos</span>
                            <span class="px-3 py-1 bg-[#39ff14]/10 border border-[#39ff14]/30 rounded-full text-[#39ff14] text-xs">Estrategia Web</span>
                            <span class="px-3 py-1 bg-[#39ff14]/10 border border-[#39ff14]/30 rounded-full text-[#39ff14] text-xs">Rendimiento Técnico</span>
                        </div>
                        <a href="https://agrosilver.cl" target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-[#39ff14] text-sm font-semibold group-hover:gap-3 gap-2 transition-all">
                            Ver proyecto 
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Filosofía (Layout Split) -->
    <section id="filosofia" class="py-20" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.6), rgba(5, 5, 17, 0.8));">
        <div class="container mx-auto px-4 flex flex-col md:flex-row items-center gap-12">
            <div class="w-full md:w-1/2 relative">
                <!-- Toroide Imagen -->
                <div class="relative aspect-square max-w-md mx-auto">
                    <img src="/toroide.webp" alt="Toroide SEMTIC - Filosofía de diseño web y desarrollo digital continuo" class="toroide-image" loading="lazy">
                </div>
            </div>
            <div class="w-full md:w-1/2">
                <h2 class="text-4xl md:text-5xl font-[family-name:var(--font-space-grotesk)] font-bold mb-6">Por qué nuestro <span class="text-gradient">Toroide</span> multiplica ventas</h2>
                <p class="text-gray-400 mb-6 leading-relaxed">
                    Al igual que la energía infinita de un toroide, creemos en los ecosistemas de ventas autosostenibles. Tu sitio web capta leads, las campañas los alimentan, y los datos nos permiten refinar todo el proceso. ¿El resultado? Un crecimiento comercial imparable.
                </p>
                <ul class="space-y-6">
                    <li class="flex items-start space-x-4">
                        <span class="w-3 h-3 mt-1.5 bg-[#00f2ea] rounded-full shadow-[0_0_10px_#00f2ea] shrink-0"></span>
                        <div>
                            <span class="text-white font-bold block mb-1">Mejora Continua de Rentabilidad</span>
                            <span class="text-gray-400 text-sm">Optimizamos mensualmente para que tu costo por adquisición baje y tus ganancias netas suban.</span>
                        </div>
                    </li>
                    <li class="flex items-start space-x-4">
                        <span class="w-3 h-3 mt-1.5 bg-[#4f46e5] rounded-full shadow-[0_0_10px_#4f46e5] shrink-0"></span>
                        <div>
                            <span class="text-white font-bold block mb-1">Diseño enfocado 100% en el Usuario</span>
                            <span class="text-gray-400 text-sm">Cada botón, color y frase está diseñado psicológicamente para que tus visitantes decidan comprar.</span>
                        </div>
                    </li>
                    <li class="flex items-start space-x-4">
                        <span class="w-3 h-3 mt-1.5 bg-[#39ff14] rounded-full shadow-[0_0_10px_#39ff14] shrink-0"></span>
                        <div>
                            <span class="text-white font-bold block mb-1">Crecimiento Predecible</span>
                            <span class="text-gray-400 text-sm">Convierte la incertidumbre en un robusto sistema de adquisición de prospectos las 24 horas.</span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </section>


    <!-- Contacto / CTA -->
    <section id="contacto" class="py-24 relative overflow-hidden" style="z-index: 10; background: linear-gradient(to bottom, rgba(5, 5, 17, 0.8), rgba(5, 5, 17, 0.95));">
        <div class="absolute inset-0 bg-[#4f46e5]/5" style="z-index: -1;"></div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h2 class="text-4xl md:text-5xl font-[family-name:var(--font-space-grotesk)] font-bold mb-8">¿Listo para <span class="text-gradient">despegar</span>?</h2>
            <p class="text-gray-400 mb-10 max-w-xl mx-auto">
                Cuéntanos sobre tu proyecto. Analizamos, diseñamos y codificamos la solución perfecta para ti.
            </p>
            
            <a href="https://wa.me/56988169404?text=Hola%20Semtic!%20Estoy%20buscando%20escalar%20las%20ventas%20de%20mi%20negocio%20digital%20y%20me%20gustaría%20recibir%20asesoría." target="_blank" class="inline-flex items-center px-10 py-5 bg-gradient-to-r from-[#25D366] to-[#00f2ea] rounded-full text-[#050511] font-extrabold text-lg tracking-wide shadow-lg hover:shadow-[0_0_40px_rgba(0,242,234,0.5)] transition-all duration-300 transform hover:-translate-y-1">
                <svg class="w-6 h-6 mr-3" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Escríbenos por WhatsApp
            </a>
        </div>
    </section>


    <script>
        function initTorusCanvas() {
            const canvas = document.getElementById('torusCanvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');

            let width, height;
            let particles = [];
            let animationFrameId;
            let isVisible = false; // Se activará por el observer
            
            // 4. Accesibilidad: Reduce Motion
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const timeMultiplier = prefersReducedMotion ? 0.05 : 1;
            const speedMultiplier = prefersReducedMotion ? 0 : 1;

            const colors = ['#2dd4bf', '#3b82f6', '#4f46e5', '#818cf8'];

            // 3. Optimización de Resolución (DPR limit)
            function resize() {
                const maxDpr = window.innerWidth < 768 ? 1.5 : 2; // Limita estrés de GPU en móviles y pantallas ultra-alta res
                const dpr = Math.min(window.devicePixelRatio || 1, maxDpr);
                width = window.innerWidth;
                height = window.innerHeight;
                
                canvas.width = width * dpr;
                canvas.height = height * dpr;
                canvas.style.width = width + 'px';
                canvas.style.height = height + 'px';
                
                ctx.setTransform(dpr, 0, 0, dpr, 0, 0); // Escala el contexto sin acumular transformaciones
            }

            class Particle {
                constructor() {
                    this.reset();
                }

                reset() {
                    this.u = Math.random() * Math.PI * 2;
                    this.v = Math.random() * Math.PI * 2;
                    
                    this.R = 200 + Math.random() * 50;
                    this.r = 80 + Math.random() * 20;

                    this.color = colors[Math.floor(Math.random() * colors.length)];
                    this.size = Math.random() * 1.5;
                    this.speedU = (0.002 + Math.random() * 0.005) * speedMultiplier;
                    this.speedV = (0.001 + Math.random() * 0.003) * speedMultiplier;
                }

                update(timeInSecs) {
                    this.u += this.speedU;
                    this.v += this.speedV;

                    let x3d = (this.R + this.r * Math.cos(this.u)) * Math.cos(this.v);
                    let y3d = (this.R + this.r * Math.cos(this.u)) * Math.sin(this.v);
                    let z3d = this.r * Math.sin(this.u);

                    const time = timeInSecs * 0.3 * timeMultiplier;
                    
                    let yTemp = y3d * Math.cos(time) - z3d * Math.sin(time);
                    let zTemp = y3d * Math.sin(time) + z3d * Math.cos(time);
                    y3d = yTemp;
                    z3d = zTemp;

                    let xTemp = x3d * Math.cos(time * 0.5) - z3d * Math.sin(time * 0.5);
                    z3d = x3d * Math.sin(time * 0.5) + z3d * Math.cos(time * 0.5);
                    x3d = xTemp;

                    const scale = 800 / (800 + z3d);
                    this.x2d = width / 2 + x3d * scale;
                    this.y2d = height / 2 + y3d * scale;
                    this.alpha = scale;
                }

                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x2d, this.y2d, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = this.color;
                    ctx.globalAlpha = Math.max(0.1, (this.alpha - 0.5));
                    ctx.fill();
                    ctx.globalAlpha = 1;
                }
            }

            const particleCount = window.innerWidth < 768 ? 300 : window.innerWidth < 1024 ? 500 : 800; // Reducción técnica para mejor rendimiento
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }

            let startTime = Date.now();
            let pauseTimeOffset = 0;
            let lastPauseTime = 0;

            function animate() {
                if (!isVisible) return; 
                
                ctx.fillStyle = 'rgba(5, 5, 17, 0.2)'; 
                ctx.fillRect(0, 0, width, height);

                const timeInSecs = (Date.now() - startTime - pauseTimeOffset) / 1000;

                particles.forEach(p => {
                    p.update(timeInSecs);
                    p.draw();
                });

                animationFrameId = requestAnimationFrame(animate);
            }

            let resizeTimeout;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(resize, 150); // Debounce para no ahogar la UI al redimensionar
            });
            resize();

            // 2. Intersection Observer (Pausar si no se ve)
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        if (!isVisible) {
                            isVisible = true;
                            if (lastPauseTime > 0) {
                                pauseTimeOffset += Date.now() - lastPauseTime;
                            }
                            animate();
                        }
                    } else {
                        isVisible = false;
                        cancelAnimationFrame(animationFrameId);
                        lastPauseTime = Date.now();
                    }
                });
            }, { threshold: 0 }); // Con threshold 0 se pausa apenas desaparece
            
            // Observar el contenedor principal del hero (asumiendo que el canvas cubre esa área)
            const heroSection = document.getElementById('home');
            if (heroSection) {
                observer.observe(heroSection);
            } else {
                isVisible = true;
                animate();
            }
        }

        // 1. Carga Diferida (Non-blocking render)
        if (typeof window !== 'undefined') {
            window.addEventListener('load', () => {
                if (window.requestIdleCallback) {
                    requestIdleCallback(initTorusCanvas, { timeout: 1000 });
                } else {
                    setTimeout(initTorusCanvas, 200);
                }
            });
        }
    </script>

</Layout>
